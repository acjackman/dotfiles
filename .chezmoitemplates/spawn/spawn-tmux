#!/usr/bin/env bash
set -euo pipefail

# Spawn a tmux window or session and send a launch command into it.
# Usage: spawn-tmux.sh --window|--session --name <name> --dir <path> --prompt <file>

usage() {
    echo "Usage: spawn-tmux.sh --window|--session --name <name> --dir <path> --prompt <file>"
    exit 1
}

mode="" name="" dir="" prompt=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --window)  mode="window";  shift ;;
        --session) mode="session"; shift ;;
        --name)    name="$2";      shift 2 ;;
        --dir)     dir="$2";       shift 2 ;;
        --prompt)  prompt="$2";    shift 2 ;;
        *) usage ;;
    esac
done

[[ -z "$mode" || -z "$name" || -z "$dir" || -z "$prompt" ]] && usage
[[ ! -d "$dir" ]] && echo "Error: directory '$dir' does not exist" && exit 1
[[ ! -f "$prompt" ]] && echo "Error: prompt file '$prompt' does not exist" && exit 1

launch_script="$HOME/.claude/skills/spawn/launch.sh"

# Derive Claude session name from the worktree directory
claude_session_name=$(tmux-window-name "$dir")

# Derive tmux name from the worktree path using shared naming conventions
if [[ "$mode" == "window" ]]; then
    tmux_name=$(tmux-window-name "$dir")
    pane_id=$(tmux new-window -d -n "$tmux_name" -c "$dir" -P -F "#{pane_id}")
    tmux set-option -t "$pane_id" automatic-rename off
    tmux send-keys -t "$pane_id" "$launch_script --session-name '$claude_session_name' '$prompt'" Enter
elif [[ "$mode" == "session" ]]; then
    tmux_name=$(tmux-session-name "$dir")
    pane_id=$(tmux new-session -d -s "$tmux_name" -c "$dir" -P -F "#{pane_id}")
    tmux set-option -t "$pane_id" automatic-rename off
    tmux send-keys -t "$pane_id" "$launch_script --session-name '$claude_session_name' '$prompt'" Enter
fi

echo "Spawned $mode '$name' in $dir"
