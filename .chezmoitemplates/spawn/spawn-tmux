#!/usr/bin/env bash
set -euo pipefail

# spawn-tmux — thin compatibility shim. The tmux window/session spawn logic now
# lives in the `clank` substrate adapter (~/.local/bin/clank), which dispatches
# herdr-or-tmux by context. This wrapper preserves the old CLI (used by muscle
# memory and older callers) by delegating to `clank spawn` with the tmux backend
# forced, so its behaviour is unchanged. New code should call `clank spawn`.
#
# Usage: spawn-tmux --window|--session --name <name> --dir <path> --prompt <file> [--model <model>]

usage() {
    echo "Usage: spawn-tmux --window|--session --name <name> --dir <path> --prompt <file> [--model <model>]" >&2
    exit 1
}

mode="" name="" dir="" prompt="" model=""
while [[ $# -gt 0 ]]; do
    case "$1" in
        --window)  mode="window";  shift ;;
        --session) mode="session"; shift ;;
        --name)    name="$2";      shift 2 ;;
        --dir)     dir="$2";       shift 2 ;;
        --prompt)  prompt="$2";    shift 2 ;;
        --model)   model="$2";     shift 2 ;;
        *) usage ;;
    esac
done

[[ -z "$mode" || -z "$name" || -z "$dir" || -z "$prompt" ]] && usage

# --name is the clank tracking label (old spawn-tmux only echoed it; the tmux
# window/session name is still derived from the worktree by clank).
args=(spawn --backend tmux --cwd "$dir" --label "$name" --prompt "$prompt")
[[ "$mode" == "session" ]] && args+=(--session)
[[ -n "$model" ]] && args+=(--model "$model")

exec clank "${args[@]}"
