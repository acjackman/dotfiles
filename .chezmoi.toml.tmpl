{{- $extra_choices := list "personal" "work" -}}
{{- $extras := promptMultichoiceOnce
    . "extras"
    "Which extras should be included?"
    $extra_choices
    (list "personal")
-}}

{{- $email := promptStringOnce . "email" "Email address" -}}
{{- $hostname := promptStringOnce . "hostname" "Hostname" -}}
{{- $setHostname := promptBoolOnce . "set_hostname" "Set Hostname" -}}
{{- $default_browser := promptStringOnce . "default_browser" "Default Browser" -}}

[data]
    hostname = {{ $hostname | quote }}
    set_hostname = {{ $setHostname }}
    email    = {{ $email | quote }}
    default_browser = {{ $default_browser | quote }}
    extras = {{ $extras | toToml }}
    default_vault = {{ promptStringOnce . "default_vault" "Default Obsidian vault name" "brain" | quote }}
    extra_obsidian_vaults = {{ if hasKey . "extra_obsidian_vaults" }}{{ .extra_obsidian_vaults | toToml }}{{ else }}[]{{ end }}
    webdav_port = {{ promptIntOnce . "webdav_port" "WebDAV port for Violentmonkey sync" 56726 }}
    google_meet_app_id = "" # deprecated: now using OpenMeetInChrome.app
    # atuin
    atuin_history_filter = {{with  $filter := .atuin_history_filter}}{{$filter | toToml}}{{else}}[]{{end}}
    atuin_cwd_filter = {{with $filter := .atuin_cwd_filter}}{{$filter | toToml}}{{else}}[]{{end}}

[hooks.read-source-state.pre]
    command = ".local/share/chezmoi/.install-password-manager.sh"
