{
  "SessionStart": [
    {
      "matcher": "",
      "hooks": [
        {
          "type": "command",
          "command": "bash '~/.local/share/tmux/plugins/tmux-assistant-resurrect/hooks/claude-session-track.sh'"
        }
      ],
      "match_key": "claude-session-track"
    }
  ],
  "SessionEnd": [
    {
      "matcher": "",
      "hooks": [
        {
          "type": "command",
          "command": "bash '~/.local/share/tmux/plugins/tmux-assistant-resurrect/hooks/claude-session-cleanup.sh'"
        }
      ],
      "match_key": "claude-session-cleanup"
    }
  ]
}
