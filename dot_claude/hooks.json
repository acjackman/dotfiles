{
  "WorktreeCreate": [
    {
      "matcher": "",
      "hooks": [
        {
          "type": "command",
          "command": "~/.local/bin/claude-worktree-create"
        }
      ],
      "match_key": "claude-worktree-create"
    }
  ],
  "SessionStart": [
    {
      "matcher": "",
      "hooks": [
        {
          "type": "command",
          "command": "bash ~/.local/share/tmux/plugins/tmux-assistant-resurrect/hooks/claude-session-track.sh"
        }
      ],
      "match_key": "claude-session-track"
    }
  ],
  "PreToolUse": [
    {
      "matcher": "Bash",
      "hooks": [
        {
          "type": "command",
          "command": "~/.claude/hooks/rtk-rewrite.sh"
        }
      ],
      "match_key": "rtk-rewrite"
    }
  ],
  "SessionEnd": [
    {
      "matcher": "",
      "hooks": [
        {
          "type": "command",
          "command": "bash ~/.local/share/tmux/plugins/tmux-assistant-resurrect/hooks/claude-session-cleanup.sh"
        }
      ],
      "match_key": "claude-session-cleanup"
    }
  ]
}
