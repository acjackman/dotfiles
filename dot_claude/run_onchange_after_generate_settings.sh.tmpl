#!/bin/bash
# permissions hash: {{ include "dot_claude/permissions.json" | sha256sum }}
# hooks hash: {{ include "dot_claude/hooks.json" | sha256sum }}
# statusline hash: {{ include "dot_claude/statusline.json.tmpl" | sha256sum }}
# defaults hash: {{ include "dot_claude/settings-defaults.json" | sha256sum }}
# settings hash: {{ output "sh" "-c" (print "cat " (joinPath .chezmoi.homeDir ".claude/settings.json") " " (joinPath .chezmoi.homeDir ".config/claude/profiles/*/settings.json") " 2>/dev/null | sha256sum || echo none") | trim | splitList " " | first }}
# profiles hash: {{ output "sh" "-c" (print "ls -d " (joinPath .chezmoi.homeDir ".config/claude/profiles/*/") " 2>/dev/null | sort | sha256sum || echo none") | trim | splitList " " | first }}

SOURCE_DIR="{{ .chezmoi.sourceDir }}/dot_claude"
PERMISSIONS_FILE="$SOURCE_DIR/permissions.json"
HOOKS_FILE="$SOURCE_DIR/hooks.json"
DEFAULTS_FILE="$SOURCE_DIR/settings-defaults.json"
STATUSLINE_FILE="$HOME/.claude/statusline.json"

if ! command -v jq &> /dev/null; then
    echo "Warning: jq not found. Cannot update Claude settings automatically."
    exit 1
fi

PERMISSIONS=$(cat "$PERMISSIONS_FILE")
# NOTE: enabledPlugins / extraKnownMarketplaces are intentionally NOT managed here.
# Plugin + marketplace state is per-config-dir (each CLAUDE_CONFIG_DIR has its own
# plugins/ tree), so run_onchange_after_install-plugins.sh owns it authoritatively
# via the `claude plugin` CLI, per profile. Hand-writing enabledPlugins here (the
# old approach) merged additively and never pruned, which caused stale-plugin drift.
DECLARED_HOOKS=$(cat "$HOOKS_FILE")
STATUSLINE=$(jq '.statusLine' "$STATUSLINE_FILE")
DEFAULTS=$(cat "$DEFAULTS_FILE")

# Sync declared hooks into settings, identified by "match_key" (a substring
# present in the command). For each declared hook, drop any existing entry
# whose hook commands match the key, then append the fresh entry. This keeps
# user-added hooks (no matching key) intact while replacing stale versions
# of declared hooks. The "match_key" field is stripped from the output.
ensure_hooks() {
    local settings_file="$1"
    local events
    events=$(jq -r 'keys[]' <<< "$DECLARED_HOOKS")

    for event in $events; do
        local count
        count=$(jq -r --arg e "$event" '.[$e] | length' <<< "$DECLARED_HOOKS")

        for ((i=0; i<count; i++)); do
            local match_key entry existing_cmd declared_cmd action
            match_key=$(jq -r --arg e "$event" --argjson i "$i" '.[$e][$i].match_key' <<< "$DECLARED_HOOKS")
            entry=$(jq --arg e "$event" --argjson i "$i" '.[$e][$i] | del(.match_key)' <<< "$DECLARED_HOOKS")
            declared_cmd=$(jq -r '.hooks[0].command // ""' <<< "$entry")

            existing_cmd=$(jq -r --arg e "$event" --arg k "$match_key" \
                'first(.hooks[$e][]? | .hooks[]? | select((.command // "") | contains($k)) | .command) // ""' \
                "$settings_file")

            if [ "$existing_cmd" = "$declared_cmd" ]; then
                continue
            fi

            if [ -n "$existing_cmd" ]; then
                action="Updated"
                # Drop any existing entries whose hooks reference this match_key
                jq --arg e "$event" --arg k "$match_key" '
                    if .hooks[$e] then
                        .hooks[$e] |= map(select(
                            (.hooks // []) | all((.command // "") | contains($k) | not)
                        ))
                    else . end
                ' "$settings_file" > "$settings_file.tmp" && mv "$settings_file.tmp" "$settings_file"
            else
                action="Added"
            fi

            jq --arg e "$event" --argjson entry "$entry" '
                .hooks //= {} |
                .hooks[$e] //= [] |
                .hooks[$e] += [$entry]
            ' "$settings_file" > "$settings_file.tmp" && mv "$settings_file.tmp" "$settings_file"

            echo "  $action hook: $event ($match_key)"
        done
    done
}

apply_settings() {
    local settings_file="$1"

    if [ ! -f "$settings_file" ]; then
        echo '{}' > "$settings_file"
    fi

    local existing
    existing=$(cat "$settings_file")

    # Build the updated settings:
    # 1. Start with defaults (lowest priority)
    # 2. Overlay existing settings (preserves Claude-managed values, incl.
    #    enabledPlugins / extraKnownMarketplaces owned by install-plugins)
    # 3. Force-set managed fields (permissions, statusline)
    jq --argjson defaults "$DEFAULTS" \
       --argjson perms "$PERMISSIONS" \
       --argjson statusline "$STATUSLINE" \
       '$defaults + . |
        .permissions = $perms |
        .statusLine = $statusline |
        .autoUpdaterStatus = "disabled"' \
        <<< "$existing" > "$settings_file.tmp" && \
        mv "$settings_file.tmp" "$settings_file"

    # Merge declared hooks (additive — never removes existing hooks)
    ensure_hooks "$settings_file"

    echo "Updated: $settings_file"
}
{{ if has "moov" .extras }}
# Merge Honeycomb OTEL env into settings.json. Key seeded into Keychain by
# run_onchange_before_store-honeycomb-key.sh.tmpl earlier in the same apply.
apply_honeycomb_env() {
    local settings_file="$1"
    local key
    key="$(security find-generic-password -a "$USER" -s CLAUDE_CODE_HONEYCOMB_API_KEY -w 2>/dev/null)"
    if [ -z "$key" ]; then
        echo "Warning: CLAUDE_CODE_HONEYCOMB_API_KEY not in Keychain; skipping OTEL env for $settings_file" >&2
        return
    fi
    jq --arg key "$key" '
        .env = ((.env // {}) + {
            CLAUDE_CODE_ENABLE_TELEMETRY: "1",
            CLAUDE_CODE_ENHANCED_TELEMETRY_BETA: "1",
            OTEL_TRACES_EXPORTER: "otlp",
            OTEL_METRICS_EXPORTER: "otlp",
            OTEL_LOGS_EXPORTER: "otlp",
            OTEL_EXPORTER_OTLP_PROTOCOL: "http/protobuf",
            OTEL_EXPORTER_OTLP_ENDPOINT: "https://api.honeycomb.io",
            OTEL_METRIC_EXPORT_INTERVAL: "1000",
            OTEL_EXPORTER_OTLP_HEADERS: ("x-honeycomb-team=" + $key)
        })
    ' "$settings_file" > "$settings_file.tmp" && mv "$settings_file.tmp" "$settings_file"
    echo "Merged Honeycomb OTEL env: $settings_file"
}
{{ end }}
apply_settings "$HOME/.claude/settings.json"
{{ if has "moov" .extras -}}
apply_honeycomb_env "$HOME/.claude/settings.json"
{{- end }}

for profile_dir in "$HOME/.config/claude/profiles"/*/; do
    [ -d "$profile_dir" ] || continue
    apply_settings "${profile_dir}settings.json"

    # Symlink skills from global ~/.claude/skills/ into each profile
    if [ -d "$HOME/.claude/skills" ]; then
        profile_skills="${profile_dir}skills"
        if [ -L "$profile_skills" ]; then
            # Already a symlink — update if target changed
            current_target=$(readlink "$profile_skills")
            if [ "$current_target" != "$HOME/.claude/skills" ]; then
                ln -sfn "$HOME/.claude/skills" "$profile_skills"
                echo "Updated skills symlink: $profile_skills"
            fi
        elif [ -d "$profile_skills" ]; then
            echo "Warning: $profile_skills is a directory, not replacing with symlink"
        else
            ln -s "$HOME/.claude/skills" "$profile_skills"
            echo "Linked skills: $profile_skills -> ~/.claude/skills"
        fi
    fi
done
