#!/usr/bin/env bash
set -euo pipefail

# ,spawn — CLI spawn with optional AI pre-processing
# Collects a prompt, optionally uses AI to propose branch/mode/improved prompt,
# opens $EDITOR for review, then spawns a Claude agent in a worktree via tmux.

usage() {
    cat >&2 <<'EOF'
Usage: ,spawn [options] [file ...]

Spawn a Claude agent in an isolated worktree via tmux.

Input methods (combined in order):
  -p, --prompt TEXT    Inline prompt text
  stdin                Piped input
  file ...             File paths to load as prompt content

Options:
  --no-ai              Skip AI analysis; go straight to editor with raw prompt
  --yolo               Skip editor review; execute immediately with AI's proposal
  --branch NAME        Pre-set branch name (overrides AI)
  --mode window|session  Pre-set mode (overrides AI)
  --repo PATH          Target a different repo
  --base REF           Base ref for branch
  -h, --help           Show this help

Examples:
  ,spawn -p "add a readme"
  echo "fix auth bug" | ,spawn
  ,spawn task.md
  ,spawn -p "context" file1.md file2.md
  ,spawn --yolo -p "quick fix for typo in README"
EOF
    exit "${1:-1}"
}

# --- Parse arguments ---
prompt_text=""
no_ai=false
yolo=false
branch_override=""
mode_override=""
repo_arg=""
base_arg=""
files=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        -p|--prompt)
            [[ $# -lt 2 ]] && { echo "Error: $1 requires an argument" >&2; exit 1; }
            prompt_text="$2"
            shift 2
            ;;
        --no-ai)    no_ai=true;  shift ;;
        --yolo)     yolo=true;   shift ;;
        --branch)
            [[ $# -lt 2 ]] && { echo "Error: $1 requires an argument" >&2; exit 1; }
            branch_override="$2"
            shift 2
            ;;
        --mode)
            [[ $# -lt 2 ]] && { echo "Error: $1 requires an argument" >&2; exit 1; }
            mode_override="$2"
            if [[ "$mode_override" != "window" && "$mode_override" != "session" ]]; then
                echo "Error: --mode must be 'window' or 'session'" >&2
                exit 1
            fi
            shift 2
            ;;
        --repo)
            [[ $# -lt 2 ]] && { echo "Error: $1 requires an argument" >&2; exit 1; }
            repo_arg="$2"
            shift 2
            ;;
        --base)
            [[ $# -lt 2 ]] && { echo "Error: $1 requires an argument" >&2; exit 1; }
            base_arg="$2"
            shift 2
            ;;
        -h|--help)  usage 0 ;;
        -*)         echo "Error: unknown option '$1'" >&2; usage ;;
        *)          files+=("$1"); shift ;;
    esac
done

# --- Validate environment ---
if [[ -z "${TMUX:-}" ]]; then
    echo "Error: must be inside a tmux session" >&2
    exit 1
fi

# --- Collect prompt from all sources ---
collected=""

# 1. -p text
if [[ -n "$prompt_text" ]]; then
    collected="$prompt_text"
fi

# 2. stdin (if piped)
if [[ ! -t 0 ]]; then
    stdin_content=$(cat)
    if [[ -n "$stdin_content" ]]; then
        [[ -n "$collected" ]] && collected+=$'\n\n'
        collected+="$stdin_content"
    fi
fi

# 3. File contents
for f in ${files[@]+"${files[@]}"}; do
    if [[ ! -f "$f" ]]; then
        echo "Error: file not found: $f" >&2
        exit 1
    fi
    [[ -n "$collected" ]] && collected+=$'\n\n'
    collected+="--- $f ---"$'\n'
    collected+="$(cat "$f")"
done

if [[ -z "$collected" ]]; then
    echo "Error: no prompt provided. Use -p, pipe stdin, or pass file paths." >&2
    usage
fi

# --- AI analysis or skip ---
ai_system_prompt='You are a task analyzer for spawning Claude Code agents. Given a task description, output a JSON object (no markdown fences) with exactly these fields:

{
  "branch": "a short lowercase-hyphenated branch name for this task (max 40 chars), e.g. fix-auth-timeout",
  "mode": "window or session — window for small focused tasks (single-file changes, bug fixes, quick refactors), session for large tasks (multi-file changes, feature implementation, long-running work)",
  "prompt": "an improved, structured version of the task description that will be given to a Claude Code agent. Keep the original intent but make it clearer and more actionable."
}

Output only the JSON object, nothing else.'

branch=""
mode=""
final_prompt=""

if [[ "$no_ai" == true ]]; then
    branch="${branch_override:-changeme}"
    mode="${mode_override:-window}"
    final_prompt="$collected"
else
    # Try AI analysis
    ai_output=""
    if ai_output=$(claude -p --model haiku --no-session-persistence --system-prompt "$ai_system_prompt" "$collected" 2>/dev/null); then
        # Strip markdown fences if present
        ai_output=$(echo "$ai_output" | sed '/^```/d')
        # Parse JSON with jq (more robust than YAML for AI output with special chars)
        if parsed_branch=$(echo "$ai_output" | jq -r '.branch // ""' 2>/dev/null) \
            && parsed_mode=$(echo "$ai_output" | jq -r '.mode // ""' 2>/dev/null) \
            && parsed_prompt=$(echo "$ai_output" | jq -r '.prompt // ""' 2>/dev/null) \
            && [[ -n "$parsed_branch" && -n "$parsed_mode" && -n "$parsed_prompt" ]]; then
            branch="$parsed_branch"
            mode="$parsed_mode"
            final_prompt="$parsed_prompt"
        else
            echo "Warning: AI returned unparseable output, falling back to raw prompt" >&2
            branch="${branch_override:-changeme}"
            mode="${mode_override:-window}"
            final_prompt="$collected"
        fi
    else
        echo "Warning: AI analysis failed, falling back to raw prompt" >&2
        branch="${branch_override:-changeme}"
        mode="${mode_override:-window}"
        final_prompt="$collected"
    fi

    # CLI overrides take precedence over AI
    [[ -n "$branch_override" ]] && branch="$branch_override"
    [[ -n "$mode_override" ]] && mode="$mode_override"
fi

# Validate mode
if [[ "$mode" != "window" && "$mode" != "session" ]]; then
    mode="window"
fi

# --- Editor review (unless --yolo) ---
if [[ "$yolo" != true ]]; then
    tmpfile=$(mktemp "${TMPDIR:-/tmp}/spawn-XXXXXX.md")
    trap 'rm -f "$tmpfile"' EXIT

    # Build markdown with YAML frontmatter for editor review
    # Frontmatter holds metadata; body is the prompt (free-form markdown)
    {
        echo "---"
        # Use yq to safely encode frontmatter values
        yq -n \
            --arg branch "$branch" \
            --arg mode "$mode" \
            --arg base "$base_arg" \
            --arg repo "$repo_arg" \
            '.branch = $branch | .mode = $mode | .base = $base | .repo = $repo'
        echo "---"
        echo ""
        echo "<!-- Spawn Agent — edit and save to proceed, clear 'branch' to abort -->"
        echo ""
        echo "$final_prompt"
    } > "$tmpfile"

    "${EDITOR:-vi}" "$tmpfile"

    # Parse edited file: extract YAML frontmatter and markdown body
    # Frontmatter = lines between first two '---' markers; body = everything after
    frontmatter=$(awk 'BEGIN{n=0} /^---$/{n++; next} n==1' "$tmpfile")
    # Body = everything after second '---', with leading blank lines trimmed
    final_prompt=$(awk 'BEGIN{n=0} /^---$/{n++; next} n>=2' "$tmpfile" | awk '/[^ \t]/{found=1} found')

    # Parse frontmatter values with yq (safe: frontmatter has only simple strings)
    branch=$(echo "$frontmatter" | yq -r '.branch // ""')
    mode=$(echo "$frontmatter" | yq -r '.mode // "window"')
    base_arg=$(echo "$frontmatter" | yq -r '.base // ""')
    repo_arg=$(echo "$frontmatter" | yq -r '.repo // ""')

    if [[ -z "$branch" ]]; then
        echo "Aborted: branch is empty." >&2
        exit 0
    fi

    if [[ "$mode" != "window" && "$mode" != "session" ]]; then
        echo "Error: mode must be 'window' or 'session', got '$mode'" >&2
        exit 1
    fi
fi

# --- Execute spawn pipeline ---

# Step 1: Setup worktree
setup_args=("$branch")
[[ -n "$base_arg" ]] && setup_args+=(--base "$base_arg")
[[ -n "$repo_arg" ]] && setup_args+=(--repo "$repo_arg")

worktree_json=$(spawn-setup-worktree "${setup_args[@]}")
worktree_path=$(echo "$worktree_json" | jq -r '.path')

echo "Worktree: $worktree_path"

# Step 2: Write prompt
prompt_file=$(echo "$final_prompt" | spawn-write-prompt "$worktree_path")

echo "Prompt: $prompt_file"

# Step 3: Spawn tmux
spawn-tmux "--$mode" --name "$branch" --dir "$worktree_path" --prompt "$prompt_file"
