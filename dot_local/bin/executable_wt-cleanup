#!/usr/bin/env bash
set -euo pipefail

# wt-cleanup — Safely remove merged worktrees and their branches
#
# For each non-main worktree, checks for:
#   1. Unmerged changes — local ancestry first, then GitHub PR state via `gh`
#      so squash/rebase merges (which break local ancestry) count as merged
#   2. Untracked/ignored artifacts (.tmp files, tmp/ dirs)
#
# Removal is delegated to `wt remove`, whose [pre-remove] tmux hook does the
# live-session safety checks: it aborts if a busy pane (e.g. a running claude)
# sits in the worktree, and kills idle shell panes before removal.
#
# Safe worktrees are removed automatically. Unsafe ones are skipped with
# a warning, unless --interactive is passed to prompt for confirmation.
#
# Usage: wt-cleanup [--interactive] [--dry-run]

interactive=false
dry_run=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    -i|--interactive) interactive=true; shift ;;
    -n|--dry-run) dry_run=true; shift ;;
    -h|--help)
      sed -n '3,/^$/s/^# \?//p' "$0" >&2
      exit 0
      ;;
    *)
      echo "error: unknown option: $1" >&2
      exit 1
      ;;
  esac
done

# --- Resolve default branch (worktrunk state, then origin/HEAD, then 'main') ---
# Don't infer from `worktree list | head -1`: in a bare/worktrunk layout the
# first entry is the .bare repo, not the default-branch worktree.
default_branch="$(wt config state default-branch 2>/dev/null || true)"
[[ -z "$default_branch" ]] && \
  default_branch="$(git symbolic-ref --short -q refs/remotes/origin/HEAD 2>/dev/null | sed 's|^origin/||')"
[[ -z "$default_branch" ]] && default_branch="main"

# --- GitHub PR state (catches squash/rebase merges local ancestry misses) ---
gh_repo=""
if command -v gh &>/dev/null; then
  gh_repo="$(gh repo view --json nameWithOwner --jq '.nameWithOwner' 2>/dev/null || echo "")"
fi
# Refresh remote state so PR/branch lookups are accurate; best-effort.
git fetch origin --prune --quiet 2>/dev/null || true

# Returns a branch's PR state: MERGED, CLOSED, OPEN, or NOT_FOUND.
check_pr_state() {
  local branch="$1"
  [[ -z "$gh_repo" ]] && { echo "NOT_FOUND"; return; }
  gh pr list --repo "$gh_repo" --head "$branch" --state all \
    --json state --jq '.[0].state' 2>/dev/null || echo "NOT_FOUND"
}

# --- Collect candidate worktrees (indexed array of "branch<TAB>path"; bash 3.2 safe) ---
# The .bare entry has no `branch` line, so it is skipped naturally. The
# default-branch worktree is recorded as primary_wt and excluded from removal.
worktrees=()
primary_wt=""
while IFS= read -r line; do
  case "$line" in
    worktree\ *) current_path="${line#worktree }" ;;
    branch\ *)
      current_branch="${line#branch refs/heads/}"
      path_real="$(cd "$current_path" && pwd -P)"
      if [[ "$current_branch" == "$default_branch" ]]; then
        primary_wt="$path_real"
        continue
      fi
      worktrees+=("${current_branch}"$'\t'"${path_real}")
      ;;
  esac
done < <(git worktree list --porcelain)

if [[ ${#worktrees[@]} -eq 0 ]]; then
  echo "No non-default-branch worktrees found."
  exit 0
fi

# Run `wt remove` from the primary worktree; fall back to the first worktree.
if [[ -z "$primary_wt" ]]; then
  primary_wt="$(git worktree list --porcelain | sed -n '1s/^worktree //p')"
fi

# --- Check each worktree ---
removed=0
skipped=0

for entry in "${worktrees[@]}"; do
  IFS=$'\t' read -r branch wt_path <<< "$entry"
  warnings=()
  force_delete=false

  # 1. Unmerged changes — local ancestry, then GitHub PR state (squash merges)
  if ! git merge-base --is-ancestor "$branch" "$default_branch" 2>/dev/null; then
    pr_state="$(check_pr_state "$branch")"
    if [[ "$pr_state" == "MERGED" ]]; then
      # Squash/rebase-merged: wt won't see local ancestry, so force branch delete
      force_delete=true
    else
      warnings+=("unmerged: branch '$branch' not merged into '$default_branch' (PR: ${pr_state:-none})")
    fi
  fi

  # 2. Untracked/ignored artifacts
  artifacts=()
  if [[ -d "$wt_path/tmp" ]]; then
    artifacts+=("tmp/")
  fi
  if [[ -d "$wt_path/.tmp" ]]; then
    artifacts+=(".tmp/")
  fi
  while IFS= read -r f; do
    artifacts+=("$f")
  done < <(find "$wt_path" -maxdepth 2 -name "*.tmp" -not -path "$wt_path/.git/*" 2>/dev/null || true)
  if [[ ${#artifacts[@]} -gt 0 ]]; then
    warnings+=("artifacts found: ${artifacts[*]}")
  fi

  # --- Decision ---
  if [[ ${#warnings[@]} -gt 0 ]]; then
    echo "SKIP  $branch ($wt_path)"
    for w in "${warnings[@]}"; do
      echo "  ⚠ $w"
    done

    if $interactive; then
      read -rp "  Remove anyway? [y/N] " answer
      if [[ "$answer" != [yY] ]]; then
        skipped=$((skipped + 1))
        echo ""
        continue
      fi
    else
      skipped=$((skipped + 1))
      echo ""
      continue
    fi
  fi

  if $dry_run; then
    echo "WOULD REMOVE  $branch ($wt_path)"
    removed=$((removed + 1))
    echo ""
    continue
  fi

  # --- Remove ---
  echo "REMOVE  $branch ($wt_path)"

  # Delegate to `wt remove`: its [pre-remove] tmux hook aborts on a busy pane
  # (e.g. a running claude) and clears idle shells. --force-delete only when we
  # confirmed a squash merge above (wt's own merge check would miss it).
  remove_args=(--foreground)
  $force_delete && remove_args+=(--force-delete)
  if ! wt -C "$primary_wt" remove "${remove_args[@]}" "$branch"; then
    echo "  error: wt remove failed (busy pane or hook abort?)" >&2
    skipped=$((skipped + 1))
    echo ""
    continue
  fi

  removed=$((removed + 1))
  echo ""
done

echo "Done: $removed removed, $skipped skipped."
