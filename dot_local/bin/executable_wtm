#!/usr/bin/env bash
# wtm - Merge a git worktree's branch and remove it with tmux-aware cleanup
#
# Scans all tmux panes for any whose working directory is inside the worktree.
# Idle shell panes are killed; busy panes (running apps) cause an error.
# After cleanup, switches to the default-branch session, then runs wt merge.
#
# Usage: wtm [wt-merge-flags...] [branch...]

# shellcheck source=../lib/wt-tmux-cleanup.sh
source "$(dirname "$0")/../lib/wt-tmux-cleanup.sh" merge "$@"
