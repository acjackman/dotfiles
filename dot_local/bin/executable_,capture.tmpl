#!/usr/bin/env bash
set -euo pipefail

date_str=$(date +%Y-%m-%d)
vault="{{ .default_vault }}"
file="$HOME/notes/${vault}/log/daily/${date_str}.md"
filepath="log%2Fdaily%2F${date_str}.md"

# Append an empty checkbox under ## Capture
open "obsidian://advanced-uri?vault=${vault}&filepath=${filepath}&heading=Capture&data=%0A-%20%5B%20%5D%20&mode=append&openmode=silent"
sleep 0.5

# Find the line number of the last empty checkbox
line=$(grep -n '^- \[ \] $' "$file" | tail -1 | cut -d: -f1)

# Place cursor right after the checkbox
open "obsidian://advanced-uri?vault=${vault}&filepath=${filepath}&line=${line}&column=7&viewmode=source"
