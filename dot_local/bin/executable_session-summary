#!/bin/bash
# session-summary.sh — Summarize today's login/display sessions using Claude

set +x

# Working day starts at 05:00, so before 5am we're still in yesterday's working day
if [ -z "$1" ]; then
  if [ "$(date +%H)" -lt 5 ]; then
    DATE=$(date -v-1d +%Y-%m-%d)
  else
    DATE=$(date +%Y-%m-%d)
  fi
else
  DATE="$1"
fi
NEXT_DATE=$(date -j -v+1d -f %Y-%m-%d "$DATE" +%Y-%m-%d)
WORKSPACE=$(mktemp -d "${TMPDIR:-/tmp}/session-summary.XXXXXX")
trap 'rm -rf "$WORKSPACE"' EXIT
OUTFILE="$WORKSPACE/output.md"
DATAFILE="$WORKSPACE/events.log"
PROMPTFILE="$WORKSPACE/prompt.txt"

# A working day runs 05:00 on $DATE through 04:59 on $NEXT_DATE
gum spin --spinner dot --title "Collecting power events for $DATE..." -- sleep 0 &
pmset -g log | grep -E '(Sleep |DarkWake|Wake |Display is turned)' \
  | grep -E "($DATE (0[5-9]|[12][0-9])|$NEXT_DATE 0[0-4])" >"$DATAFILE"
wait

if [ ! -s "$DATAFILE" ]; then
  echo "No power management events found for $DATE"
  exit 1
fi

EVENT_COUNT=$(wc -l <"$DATAFILE" | tr -d ' ')
gum style --faint "$EVENT_COUNT events found"

cat <<EOF >"$PROMPTFILE"
You are analyzing macOS power management logs to determine when the user was actively using their computer.
The working day is $DATE 05:00 through $NEXT_DATE 04:59.
The logs are in the file: $DATAFILE

Rules:
- A session STARTS when "Display is turned on" (user-initiated wake)
- A session ENDS when "Display is turned off", or "Entering Sleep state"
- Ignore DarkWake events (those are background system maintenance, not user activity)
- Collapse sessions that are less than 5 minutes apart into a single session
- Use the local time from the log entries (they include timezone offset)

Write ONLY a single markdown table with columns: Block, Time Range, Duration, Notes to the file: $OUTFILE
- Block: a short human-friendly label like "Morning", "Afternoon", "Evening", "Brief open", "Return", etc.
- Time Range: use 24-hour format (e.g. 08:39 → 11:08), use "?" for unknown start/end, "ongoing" if still active at end of log
- Duration: approximate (e.g. ~2h 29m)
- Notes: brief context like "Main work block", "Quick lid open/close", "Ended by clamshell close"
No headers, no analysis, no extra text — just the table.
EOF

gum spin --spinner dot --title "Generating session summary..." -- \
  bash -c "cd $WORKSPACE && cat $PROMPTFILE | claude -p --model haiku --allowedTools 'Read,Write' >&2"

cat "$OUTFILE"
