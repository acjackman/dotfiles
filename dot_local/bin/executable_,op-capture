#!/usr/bin/env zsh

# Usage: ,op-capture [content]
# Creates a new 1Password note titled "Capture YYYY-MM-DDTHH:MM:SS-TZ"
# Content can be provided via stdin, arguments, or by opening an editor

timestamp=$(date '+%Y-%m-%dT%H:%M:%S')
title="Capture $timestamp"

content=""

if [ ! -t 0 ]; then
  content=$(cat)
elif [ $# -gt 0 ]; then
  content=""
  for file in "$@"; do
    if [ -f "$file" ]; then
      [[ -n "$content" ]] && content+=$'\n'
      content+="$(cat "$file")"
    else
      echo "Warning: $file is not a file, skipping"
    fi
  done
else
  tmpfile=$(mktemp -t "op-capture.XXXXXX")
  editor="${EDITOR:-vim}"

  if [[ "$editor" =~ "vim" ]]; then
    editor="$editor -c 'startinsert'"
  fi

  $editor "$tmpfile"

  if [ -s "$tmpfile" ]; then
      content=$(cat "$tmpfile")
  fi

  rm -f "$tmpfile"
fi

if [ -z "$content" ]; then
  echo "No content provided, note not created"
  exit 1
fi

if ! command -v jq >/dev/null 2>&1; then
  echo "Error: 'jq' is required but not installed. Please install jq to continue."
  exit 1
fi

template_json=$(cat <<'JSON'
{
  "title": "",
  "category": "SECURE_NOTE",
  "fields": [
    {
      "id": "notesPlain",
      "type": "STRING",
      "purpose": "NOTES",
      "label": "notesPlain",
      "value": ""
    }
  ]
}
JSON
)

echo "$template_json" | jq \
  --arg title "$title" \
  --arg notes "$content" \
  '.title = $title | .fields |= map(if .id == "notesPlain" then .value = $notes else . end)' | \
  op item create --vault "Private" --account="jackman.1password.com" - > /dev/null

create_status=$?

if [ $create_status -eq 0 ]; then
  echo "Note '$title' created successfully"
else
  echo "Failed to create note"
  exit 1
fi
