#!/usr/bin/env bash

mode="session"
while [[ $# -gt 0 ]]; do
  case "$1" in
    --new-window) mode="new-window"; shift ;;
    --window) mode="window"; shift ;;
    --move-window) mode="move-window"; shift ;;
    *) break ;;
  esac
done

dir="${1:-.}"

# Capture wt's directive file to extract the cd path instead of sourcing it
directive_file="$(mktemp)"
trap 'rm -f "$directive_file"' EXIT

WORKTRUNK_DIRECTIVE_FILE="$directive_file" command wt -C "$dir" switch

if [[ ! -s "$directive_file" ]]; then
  exit 0
fi

# Extract path from directive like: cd '/path/to/worktree'
path=$(sed -n "s/^cd '\\(.*\\)'/\\1/p; s/^cd //p" "$directive_file" | head -1)

if [[ -z "$path" ]]; then
  exit 0
fi

# Derive session name for reuse checks
session=$(tmux-session-name "$path")

# Window mode: prefer existing session, ensure a window exists for the path
if [[ "$mode" == "window" ]]; then
  name=$(tmux-window-name "$path")
  if tmux has-session -t "=$session" 2>/dev/null; then
    tmux switch-client -t "=$session"
    # Ensure the session has a window for this path
    tmux select-window -t "=$session:=$name" 2>/dev/null || \
      tmux new-window -t "=$session" -n "$name" -c "$path"
  else
    tmux select-window -t ":=$name" 2>/dev/null || \
      tmux new-window -n "$name" -c "$path"
  fi
  exit 0
fi

if [[ "$mode" == "move-window" ]]; then
  # Write info for the tmux binding to handle after popup closes
  printf '%s\n%s\n' "$session" "$path" > /tmp/wt-move-window-pending
elif [[ "$mode" == "new-window" ]]; then
  # Ensure the session exists, then write info for the tmux binding to handle
  if ! tmux has-session -t "=$session" 2>/dev/null; then
    tmux new-session -d -s "$session" -c "$path"
  fi
  printf '%s\n%s\n' "$session" "$path" > /tmp/wt-ghostty-pending
else
  if ! tmux has-session -t "=$session" 2>/dev/null; then
    tmux new-session -d -s "$session" -c "$path"
  fi
  tmux switch-client -t "=$session"
fi
