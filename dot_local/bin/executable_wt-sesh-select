#!/usr/bin/env bash

mode="session"
while [[ $# -gt 0 ]]; do
  case "$1" in
    --new-window) mode="new-window"; shift ;;
    --window) mode="window"; shift ;;
    *) break ;;
  esac
done

dir="${1:-.}"

# Capture wt's directive file to extract the cd path instead of sourcing it
directive_file="$(mktemp)"
trap 'rm -f "$directive_file"' EXIT

WORKTRUNK_DIRECTIVE_FILE="$directive_file" command wt -C "$dir" switch

if [[ ! -s "$directive_file" ]]; then
  exit 0
fi

# Extract path from directive like: cd '/path/to/worktree'
path=$(sed -n "s/^cd '\\(.*\\)'/\\1/p; s/^cd //p" "$directive_file" | head -1)

if [[ -z "$path" ]]; then
  exit 0
fi

# Window mode: switch to or create a window named after the worktree
if [[ "$mode" == "window" ]]; then
  name=$(tmux-window-name "$path")
  tmux select-window -t ":=$name" 2>/dev/null || \
    tmux new-window -n "$name" -c "$path"
  exit 0
fi

# Session/new-window modes: use shared session naming
session=$(tmux-session-name "$path")

if [[ "$mode" == "new-window" ]]; then
  # Activate existing Ghostty window for this session if one exists
  found=$(osascript -e '
tell application "System Events"
    tell process "Ghostty"
        set windowNames to name of every window
        repeat with i from 1 to count of windowNames
            if item i of windowNames contains "'"$session"'" then
                perform action "AXRaise" of window i
                return "found"
            end if
        end repeat
    end tell
end tell
return "not_found"
' 2>/dev/null)
  if [[ "$found" == "found" ]]; then
    osascript -e 'tell application "Ghostty" to activate'
  else
    open -na Ghostty.app --args -e tmux new-session -A -s "$session" -c "$path"
  fi
else
  if ! tmux has-session -t "=$session" 2>/dev/null; then
    tmux new-session -d -s "$session" -c "$path"
  fi
  tmux switch-client -t "=$session"
fi
