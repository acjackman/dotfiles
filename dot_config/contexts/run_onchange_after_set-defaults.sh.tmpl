{{ if eq .chezmoi.os "darwin" -}}
#!/usr/bin/env bash

# Appearance
defaults write com.contextsformac.Contexts CTAppearanceTheme -string "CTAppearanceNamedAuto"

# Sidebar: disabled
defaults write com.contextsformac.Contexts CTPreferenceSidebarDisplayMode -string "CTDisplayModeNone"
defaults write com.contextsformac.Contexts CTSidebarHorizontalAlignment -string "CTWindowHorizontalAlignmentRight"
defaults write com.contextsformac.Contexts CTSidebarVerticalAlignment -string "CTWindowVerticalAlignmentCenter"
defaults write com.contextsformac.Contexts CTSidebarInactiveMaximumWidth -int 5

# Gestures
defaults write com.contextsformac.Contexts CTPreferenceInputDoubleTouchSwitchGestureActive -bool true

# Search shortcut: function key disabled
defaults write com.contextsformac.Contexts CTPreferenceSearchShortcutFunctionKeyEnabled -bool false

# Search shortcut (Cmd+Space)
defaults write com.contextsformac.Contexts CTPreferenceSearchShortcutModal -data ""

# Switchers configuration
defaults write com.contextsformac.Contexts CTPreferenceSwitchers -data ""

# Auto-update
defaults write com.contextsformac.Contexts SUEnableAutomaticChecks -bool true
{{ end -}}
