{{ if eq .chezmoi.os "darwin" -}}
#!/usr/bin/env bash
set -euo pipefail

# Cheatsheet content hash (triggers regeneration on edits):
# {{ output "find" (joinPath .chezmoi.sourceDir "dot_config/dash/cheatsheets") "-name" "*.yaml" "-exec" "shasum" "-a" "256" "{}" ";" | sha256sum }}

# Source cheatsheets directory
src="{{ .chezmoi.sourceDir }}/dot_config/dash/cheatsheets"
# Dash cheat sheets install directory
dest="$HOME/Library/Application Support/Dash/Cheat Sheets"
generator="$src/generate-docset.py"

cd "$src"

for yaml in *.yaml; do
  [ -f "$yaml" ] || continue

  # Extract docset_file_name from YAML
  name=$(sed -n 's/^docset_file_name:[[:space:]]*//p' "$yaml")
  if [ -z "$name" ]; then
    echo "WARNING: No docset_file_name found in $yaml, skipping" >&2
    continue
  fi

  echo "Generating $name from $yaml..."
  uv run "$generator" "$yaml"

  # Install into Dash's cheat sheets directory
  mkdir -p "$dest/$name"
  rm -rf "$dest/$name/$name.docset"
  mv "$name.docset" "$dest/$name/"

  # Tell Dash to pick up the docset
  open "$dest/$name/$name.docset"
done
{{ end -}}
