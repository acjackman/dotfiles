# -*- mode: zsh -*- vim: ft=zsh

# ,t - Tmux session launcher with optional session name argument
#
# Usage:
#   ,t            Launch interactive picker
#   ,t <name>     Exact match → connect directly; partial → prefill picker query
#
# Outside tmux: exec into the launcher so the window closes with the session
# Inside tmux: run normally so sesh handles session switching

# Check if this terminal is actually a tmux client (not just a stale $TMUX env)
_in_tmux() {
  [[ -n "$TMUX" ]] && tmux list-clients -F '#{client_tty}' 2>/dev/null | grep -qF "$(tty)"
}

# If an argument is provided, try exact match first
if [[ -n "$1" ]]; then
  local query="$*"
  local sessions
  sessions="$(sesh list 2>/dev/null)"

  # Exact match: connect directly
  if echo "$sessions" | grep -qxF "$query"; then
    sesh connect "$query"
    return $?
  fi
fi

# Launch the picker script (with optional query for partial match)
if _in_tmux; then
  ~/.config/tmux/tmux_launcher.sh "${query-}"
else
  TMUX= exec ~/.config/tmux/tmux_launcher.sh "${query-}"
fi
