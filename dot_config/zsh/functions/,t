# -*- mode: zsh -*- vim: ft=zsh

# ,t - Tmux session launcher
#
# Outside tmux: exec into the launcher so the window closes with the session
# Inside tmux: run normally so sesh handles session switching

# Check if this terminal is actually a tmux client (not just a stale $TMUX env)
_in_tmux() {
  [[ -n "$TMUX" ]] && tmux list-clients -F '#{client_tty}' 2>/dev/null | grep -qF "$(tty)"
}

if _in_tmux; then
  ~/.config/tmux/tmux_launcher.sh
else
  TMUX= exec ~/.config/tmux/tmux_launcher.sh
fi
