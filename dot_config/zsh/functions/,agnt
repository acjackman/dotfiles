# -*- mode: zsh -*- vim: ft=zsh

# ,agnt - Start Claude in the git repo root (or current dir with --here)
#
# Usage: ,agnt [--here] [claude args...]

local dir
local -a args

for arg in "$@"; do
  if [[ "$arg" == "--here" ]]; then
    dir="."
  else
    args+=("$arg")
  fi
done

if [[ -z "$dir" ]]; then
  dir="$(git rev-parse --show-toplevel 2>/dev/null)" || {
    >&2 echo ",agnt: not in a git repository"
    return 1
  }
fi

# Disable git signing for the agent subshell — non-interactive commits shouldn't
# trigger signing prompts or be attributed to the user. GIT_CONFIG_COUNT layers
# over system/global/local config without touching any files.
(
  cd "$dir" && \
  GIT_CONFIG_COUNT=3 \
  GIT_CONFIG_KEY_0=commit.gpgsign GIT_CONFIG_VALUE_0=false \
  GIT_CONFIG_KEY_1=tag.gpgsign    GIT_CONFIG_VALUE_1=false \
  GIT_CONFIG_KEY_2=push.gpgsign   GIT_CONFIG_VALUE_2=false \
  claude "${args[@]}"
)
