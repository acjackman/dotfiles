# -*- mode: zsh -*- vim: ft=zsh

# ,jg - Jump to Git Modified Directory
#
# Pushd to a modified directory in the current branch
# Skips picker if only one directory is modified

# Get the repo root
local repo_root=$(git rev-parse --show-toplevel 2>/dev/null)
if [[ -z "$repo_root" ]]; then
    echo "Not in a git repository" >&2
    return 1
fi

# Get the main branch (usually master or main)
local main_branch=""
if command -v wt >/dev/null 2>&1; then
    main_branch=$(wt -C "$repo_root" step eval '{{ default_branch }}' 2>/dev/null)
fi
if [[ -z "$main_branch" ]]; then
    main_branch=$(git -C "$repo_root" rev-parse --abbrev-ref origin/HEAD 2>/dev/null)
    if [[ $? -ne 0 || -z "$main_branch" || "$main_branch" == "origin/HEAD" || "$main_branch" == "HEAD" ]]; then
        if git -C "$repo_root" rev-parse --verify origin/main >/dev/null 2>&1; then
            main_branch="main"
        elif git -C "$repo_root" rev-parse --verify origin/master >/dev/null 2>&1; then
            main_branch="master"
        else
            echo "Could not determine default branch (origin/HEAD is unset and neither origin/main nor origin/master exists)" >&2
            return 1
        fi
    else
        main_branch="${main_branch#origin/}"
    fi
fi

# Get all directories containing modified files (repo-wide)
local -a dirs
dirs=($(
    {
        git -C "$repo_root" diff --name-only "origin/${main_branch}...HEAD" 2>/dev/null
        git -C "$repo_root" diff --name-only --cached 2>/dev/null
        git -C "$repo_root" diff --name-only 2>/dev/null
        git -C "$repo_root" ls-files --others --exclude-standard 2>/dev/null
    } | while IFS= read -r file; do
        dir=$(dirname "$file")
        if [[ -d "${repo_root}/${dir}" ]]; then
            echo "$dir"
        fi
    done | awk '!seen[$0]++'
))

# Exit if no modified directories found
if [[ ${#dirs[@]} -eq 0 ]]; then
    echo "No modified directories found" >&2
    return 1
fi

# If only one directory, go directly there
local selected
if [[ ${#dirs[@]} -eq 1 ]]; then
    selected="${dirs[1]}"
else
    # Set up preview command
    local preview_cmd
    if command -v eza >/dev/null 2>&1; then
        preview_cmd="eza --long --group-directories-first --color=always ${repo_root}/{}"
    else
        preview_cmd="ls -la ${repo_root}/{}"
    fi

    # Multiple directories - use fzf to select
    selected=$(printf '%s\n' "${dirs[@]}" | fzf --prompt="Jump to directory: " \
        --preview="$preview_cmd" \
        --preview-window=up:75%:wrap \
        --height=100% \
        --no-multi)
fi

# Exit if no directory was selected (user cancelled fzf)
if [[ -z "$selected" ]]; then
    echo "No directory selected" >&2
    return 0
fi

# Pushd to target directory
local target_dir="${repo_root}/${selected}"
[[ -d "$target_dir" ]] && pushd "$target_dir" > /dev/null
