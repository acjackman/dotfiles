#!/usr/bin/env bash
# hash: {{ include "dot_config/herdr/config.toml" | sha256sum }}
#
# Keep the herdr trial wired up: ensure the vim-herdr-navigation plugin is
# installed, then reload the running server's config after the keybindings in
# config.toml change. Guarded on herdr being present, so this is a clean no-op
# on machines that haven't opted into the trial (`brew "herdr"` is personal).
set -euo pipefail

command -v herdr >/dev/null 2>&1 || exit 0

# Plugins to keep installed: "<plugin_id> <owner/repo>".
#   vim-herdr-navigation   — <C-h/j/k/l> between herdr panes and Neovim splits
#   rjyo.window-title-sync — sync the terminal/Ghostty title with the focused
#                            workspace/tab/agent (event-driven; needs bun on PATH,
#                            provided by the global mise `bun` tool)
#   worktrunk              — worktree switch/create/remove via worktrunk (`wt`);
#                            needs wt >= 0.60, fzf, jq (already in the toolchain)
#   kichel.muster          — agent-aware project switcher (the sesh analogue);
#                            `herdr plugin install` COMPILES it from source, so it
#                            needs a Rust toolchain — provided by `brew "rust"` in
#                            Brewfile-base. Projects it offers are configured in
#                            plugins/config/kichel.muster/config.toml.
#   rmarganti.herdr-pluck  — tmux-fingers-style hint picker: copy a visible token
#                            with a keyboard hint (prefix+space). Ships prebuilt
#                            binaries for macOS Apple Silicon / Linux x86_64, else
#                            builds via Cargo (Rust already present). Copies with
#                            macOS `pbcopy` (built in).
plugins=(
  "vim-herdr-navigation paulbkim-dev/vim-herdr-navigation"
  "rjyo.window-title-sync rjyo/herdr-window-title-sync"
  "worktrunk devashish2203/herdr-worktrunk"
  "kichel.muster marcoskichel/herdr-muster"
  "rmarganti.herdr-pluck rmarganti/herdr-pluck"
)

installed="$(herdr plugin list 2>/dev/null || true)"
for entry in "${plugins[@]}"; do
  id="${entry%% *}"
  repo="${entry##* }"
  if ! grep -q "$id" <<<"$installed"; then
    echo "Installing $id plugin…"
    herdr plugin install "$repo" --yes
  fi
done

# Reload config in the running server; harmless no-op when none is up.
if herdr server reload-config >/dev/null 2>&1; then
  echo "herdr config reloaded"
fi
