// logic lives in the static buildConfig.js, fed by the rendered extras.json.

import extras from "{{ .chezmoi.homeDir }}/.config/finicky/extras.json";
import { buildConfig } from "{{ .chezmoi.homeDir }}/.config/finicky/buildConfig.js";

export default buildConfig(extras);
