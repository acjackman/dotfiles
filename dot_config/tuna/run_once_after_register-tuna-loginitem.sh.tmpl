{{- if eq .chezmoi.os "darwin" -}}
#!/usr/bin/env bash
# Register Tuna as a macOS login item so it starts at login. Modern macOS
# stores login items in backgroundtaskmanagementd (not in Tuna's plist), so
# the setting doesn't follow the dotfiles. The first invocation on a new mac
# triggers an Automation prompt for System Events.
#
# Idempotent: re-runs are no-ops once the item exists. chezmoi runs this
# script at most once per machine anyway (run_once_ hash-tracked).

set -euo pipefail

if [ ! -d /Applications/Tuna.app ]; then
  echo "Tuna.app not installed; skipping login-item registration."
  exit 0
fi

osascript <<'APPLESCRIPT'
tell application "System Events"
  if not (exists login item "Tuna") then
    make login item at end with properties {path:"/Applications/Tuna.app", hidden:true}
  end if
end tell
APPLESCRIPT

echo "Tuna registered as a login item."
{{ end -}}
