{{- if eq .chezmoi.os "darwin" -}}
#!/usr/bin/env bash

# Checksums (re-run when any fragment changes):
# - catalogs: {{ include ".chezmoitemplates/tuna/catalogs" | sha256sum }}
# - bindings: {{ include ".chezmoitemplates/tuna/bindings" | sha256sum }}
# - settings: {{ include ".chezmoitemplates/tuna/settings" | sha256sum }}

function show-header() {
  if command -v gum &>/dev/null; then
    gum style --border=double --align=left --padding "0 2" --width=75 "$@"
  else
    echo "$@"
  fi
}

config="${HOME}/.config/tuna/config.toml"

# Tuna doesn't watch its config file or expose a reload CLI, so the only way to
# apply binding/hotkey/theme edits is to quit and relaunch. The catch: Tuna
# rewrites config.toml from its *in-memory* state when it quits, so quitting a
# still-running (stale) instance clobbers the fresh config chezmoi just wrote.
#
# chezmoi has already written the new config by the time this run_onchange_after
# script executes, so we snapshot that write, let Tuna's quit clobber the file,
# then restore the snapshot before relaunching. This is deliberately
# self-contained rather than split across a run_onchange_before stop-script:
# run_onchange scripts only fire when their watched hash changes, and chezmoi's
# before/after ordering is only well-defined relative to a file-write phase —
# editing just the scripts (no config.toml change) can run them out of order.
# Snapshot-and-restore is correct regardless of order or of whether Tuna
# actually clobbers on any given quit.
show-header "Tuna"
echo "Restarting Tuna to apply config changes"

snapshot=""
if [ -f "$config" ]; then
  snapshot="$(mktemp -t tuna-config)"
  cp "$config" "$snapshot"
fi

if [ "$(osascript -e 'application "Tuna" is running' 2>/dev/null)" = "true" ]; then
  osascript -e 'tell application "Tuna" to quit' || true
  for _ in $(seq 1 40); do
    [ "$(osascript -e 'application "Tuna" is running' 2>/dev/null)" != "true" ] && break
    sleep 0.25
  done
fi

# Undo any on-quit clobber: restore the config chezmoi wrote for this apply.
if [ -n "$snapshot" ]; then
  cp "$snapshot" "$config"
  rm -f "$snapshot"
fi

# Point Tuna at the chezmoi-managed config dir. These prefs live in Tuna's
# plist, not config.toml, so they don't follow the dotfiles on their own.
# Written while Tuna is stopped so it can't clobber them on quit.
defaults write com.brnbw.Tuna ConfigSyncCustomFolderPath -string "${HOME}/.config/tuna"
defaults write com.brnbw.Tuna ConfigSyncUsesCustomFolder -bool true

if [ -d /Applications/Tuna.app ]; then
  open -a Tuna
fi
{{ end -}}
