{{ if eq .chezmoi.os "darwin" -}}
#!/usr/bin/env bash

# Settings: {{ include "data/ovim/settings.yaml" | sha256sum }}
# Launcher: {{ include "dot_config/ovim/executable_terminal-launcher.sh" | sha256sum }}

SETTINGS_DIR="$HOME/Library/Application Support/ovim"
SETTINGS_FILE="$SETTINGS_DIR/settings.yaml"
SOURCE="{{ .chezmoi.sourceDir }}/data/ovim/settings.yaml"

mkdir -p "$SETTINGS_DIR"
cp "$SOURCE" "$SETTINGS_FILE"

# Copy launcher script to where ovim expects it
cp "$HOME/.config/ovim/terminal-launcher.sh" "$SETTINGS_DIR/terminal-launcher.sh"

echo "ovim settings applied"
{{ end -}}
